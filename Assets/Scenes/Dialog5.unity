  m_Script: {fileID: 11500000, guid: feb02302d53264a4e9742c7a096c50b4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  fadeScreenIn: {fileID: 1264757316}
  textBox: {fileID: 1823989984}
  komponenTeksUtama: {fileID: 1468142211}
  komponenNamaKarakter: {fileID: 1372359635}
  tombolNext: {fileID: 1312621009}
  daftarDialog:
  - namaKarakter: Petani
    teksDialog: Prawatasari adalah tokoh perempuan pejuang yang berasal dari tanah
      Cianjur. Ia adalah putri dari seorang pemimpin lokal yang menolak tunduk kepada
      kekuasaan VOC Belanda di abad ke-17.
    suaraKarakter: {fileID: 2003527301}
    objekKarakter: {fileID: 790564425}
  - namaKarakter: Kades
    teksDialog: "Bersama suaminya, Raden Aria Cikondang, Prawatasari memimpin perlawanan
      rakyat Cianjur terhadap penjajahan. Keberaniannya menjadikannya simbol perlawanan
      \u2014 seorang perempuan yang turun langsung ke medan perjuangan."
    suaraKarakter: {fileID: 992376159}
    objekKarakter: {fileID: 502948448}
  - namaKarakter: Pemuda Kaya
    teksDialog: "Namanya diabadikan dalam berbagai jalan dan tempat di Cianjur. Prawatasari
      adalah bukti bahwa perjuangan melawan penindasan bukan hanya milik kaum lelaki
      \u2014 perempuan Cianjur pun punya tempat dalam sejarah perlawanan bangsa."
    suaraKarakter: {fileID: 193877493}
    objekKarakter: {fileID: 2046547329}
  jedaAwalGame: 2
  jedaMunculKarakter: 2
  targetScene: Tanya5
